{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WizeMe benchmark result",
  "type": "object",
  "required": ["schema_version", "system", "status", "dataset", "evaluation", "metrics", "provenance"],
  "properties": {
    "schema_version": {"enum": ["1.0", "1.1"]},
    "system": {"type": "string", "minLength": 1},
    "status": {"enum": ["complete", "partial", "not_run", "failed"]},
    "dataset": {
      "type": "object",
      "required": ["name", "variant", "revision", "kind"],
      "properties": {
        "name": {"type": "string"},
        "variant": {"type": "string"},
        "revision": {"type": "string", "pattern": "^[a-f0-9]{40}$|^unassigned$|^20"},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "kind": {"enum": ["public", "synthetic", "production-anonymized"]}
      }
    },
    "evaluation": {
      "type": "object",
      "required": ["task", "mode", "metric_definition"],
      "properties": {
        "task": {"type": "string"},
        "mode": {"enum": ["retrieval", "end_to_end_qa", "recommendation", "forgetting"]},
        "metric_definition": {"type": "string"},
        "evaluator_revision": {"type": "string"},
        "granularity": {"type": "string"}
      }
    },
    "metrics": {"type": "object"},
    "provenance": {
      "type": "object",
      "required": ["generated_at", "source", "command", "hardware", "run_count"],
      "properties": {
        "generated_at": {"type": "string"},
        "source": {"type": "string"},
        "command": {"type": "string"},
        "hardware": {"type": ["string", "object"]},
        "run_count": {"type": "integer", "minimum": 0}
      }
    }
  }
}
